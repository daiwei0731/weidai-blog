---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPost = sortedPosts.find((p) => p.data.featured);
---

<Layout title="Wei Dai" description="Notes on network engineering, AI agents, and the spaces between.">
  <main>
    <header class="site-header">
      <h1>Wei Dai</h1>
      <p class="tagline">Network engineer. Building mental models, one concept at a time.</p>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/wei-dai-279539190" target="_blank" rel="noopener noreferrer">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="/rss.xml">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
          </svg>
          RSS
        </a>
      </div>
    </header>

    <section class="about-section">
      <p class="section-label">About this blog</p>
      <div class="about-body">
        <p>
          This is where I document how I think about networking — not just how things work,
          but how to build a coherent mental model of the entire discipline.
        </p>
        <p>
          Network engineering spans a lot of territory: routing protocols, traffic engineering,
          observability, automation, and increasingly, AI-assisted operations. What I've found is
          that the engineers who navigate this complexity well aren't necessarily the ones who know
          the most facts — they're the ones who have a well-structured map of how those facts
          relate to each other.
        </p>
        <p>
          This blog is my attempt to build that map in public, and to think through what it takes
          to develop genuine technical judgment in a field that keeps moving.
        </p>
      </div>
      {featuredPost && (
        <a class="featured-post" href={`/posts/${featuredPost.id}/`}>
          <span class="featured-label">Start here</span>
          <span class="featured-title">{featuredPost.data.title}</span>
          <svg class="featured-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      )}
    </section>

    <section class="posts-section">
      <p class="section-label">Writing</p>
      {sortedPosts.map((post) => (
        <div class="post-item">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: '2-digit',
            })}
          </time>
          <div>
            <a class="post-title" href={`/posts/${post.id}/`}>{post.data.title}</a>
            <p class="post-desc">{post.data.description}</p>
          </div>
        </div>
      ))}
    </section>
  </main>
</Layout>
